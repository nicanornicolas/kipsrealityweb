# Local-only overrides for E2E/dev. Keep this file out of CI.
# Loaded after .env.test by the `test:e2e` script for safe overrides.

# Playwright browser cache location (Windows example)
# Adjust this to your own machine if needed.
PLAYWRIGHT_BROWSERS_PATH="D:\\playwright-browsers"

# SMS DRY RUN (Test env should never hit external SMS APIs)
SMS_DRY_RUN="true"
