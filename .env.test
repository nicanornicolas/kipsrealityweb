# Test Environment Configuration
# Uses MySQL 8.0 (matching production)

# MySQL 8.0 connection string for test database
DATABASE_URL="mysql://test_user:test_password@localhost:3307/rentflow_test"

# NextAuth.js configuration
NEXTAUTH_SECRET="test-secret-for-integration-tests-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# JWT secrets for testing
JWT_SECRET="test-jwt-secret-key"
JWT_REFRESH_SECRET="test-jwt-refresh-secret-key"

# App URL for testing
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mock MPESA Configuration (for testing without real API calls)
MPESA_CONSUMER_KEY="mock_consumer_key"
MPESA_CONSUMER_SECRET="mock_consumer_secret"
MPESA_SHORTCODE="123456"
MPESA_PASSKEY="mock_passkey"
MPESA_ENV="sandbox"

# Mock STRIPE Configuration (for testing without real API calls)
STRIPE_SECRET_KEY="sk_test_mock_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_mock_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_mock_webhook_secret"

# Debug mode for test output
DEBUG="false"
