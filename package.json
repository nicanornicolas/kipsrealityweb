{
  "name": "rentflow360",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "libs/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nx dev --turbo",
    "postinstall": "prisma generate",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=6144 nx build --webpack",
    "// --- DEPLOYMENT SCRIPTS ---": "",
    "postbuild": "node scripts/build-standalone.mjs",
    "start": "nx start",
    "start:standalone": "node .next/standalone/server.js",
    "worker:dev": "npx tsx watch apps/background-worker/src/main.ts",
    "worker:build": "npx nx run background-worker-app:build",
    "worker:start": "npx nx run background-worker-app:serve:production",
    "// --- DATABASE SCRIPTS ---": "",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset:test": "dotenv -e .env.test -- prisma db push --force-reset --accept-data-loss --skip-generate",
    "db:seed:test": "dotenv -e .env.test -- tsx prisma/seed.e2e.ts",
    "test:studio": "dotenv -e .env.test -- prisma studio",
    "db:studio": "prisma studio",
    "preflight:test-services": "dotenv -e .env.test -o -- node scripts/preflight-test-services.js",
    "// --- UTILITIES ---": "",
    "create-admin": "tsx scripts/create-admin.ts",
    "lint": "eslint .",
    "check:hardcoded-runtime": "node scripts/check-hardcoded-runtime.mjs",
    "clean": "rimraf .next",
    "// --- UNIT TESTING (Vitest - Milliseconds) ---": "",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "// --- INTEGRATION TESTING (Vitest + Docker DB - Seconds) ---": "",
    "test:integration": "dotenv -e .env.test -o -- vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "dotenv -e .env.test -o -- vitest --config vitest.config.integration.ts",
    "// --- E2E TESTING (Playwright - Minutes) ---": "",
    "test:e2e": "dotenv -e .env.test -e .env.test.local -- nx e2e",
    "test:e2e:ui": "nx e2e --ui",
    "test:e2e:headed": "nx e2e --headed",
    "test:e2e:ci": "nx e2e --reporter=html,json",
    "test:e2e:debug": "nx e2e --debug",
    "// --- UAT SCRIPT ALIASES (SCOPED) ---": "",
    "uat:setup:db": "npx tsx scripts/test-db.ts",
    "uat:setup:coa": "npx tsx scripts/seed-coa.ts",
    "uat:setup:utility": "npx tsx scripts/seed-utility.ts",
    "uat:setup:e2e-seed": "dotenv -e .env.test -- tsx scripts/seed-e2e.ts",
    "uat:dss:seed-notarize": "dotenv -e .env.test -- tsx scripts/seed-dss-test.ts",
    "uat:dss:notarize": "powershell -ExecutionPolicy Bypass -File scripts/test-notarize.ps1",
    "uat:payments:strategy": "npx tsx scripts/verify-payment-factory.ts",
    "uat:finance:smoke": "npx tsx scripts/smoke-gl-flow.ts",
    "uat:finance:smoke:cleanup": "npx tsx scripts/smoke-gl-flow.ts --cleanup",
    "uat:finance:verify-core": "npx tsx scripts/verify-finance.ts",
    "uat:finance:summary": "npx tsx scripts/verify-summary-api.ts",
    "uat:finance:lease-activation": "npx tsx scripts/verify-lease-activation.ts",
    "uat:finance:utilities": "npx tsx scripts/verify-utility-allocation.ts",
    "uat:finance:maintenance": "npx tsx scripts/verify-maintenance-billing.ts",
    "uat:finance:rent-roll": "npx tsx scripts/test-rent-roll.ts",
    "uat:property:listing-lifecycle": "npx tsx scripts/verify-listing-lifecycle.ts",
    "uat:property:application-lease-termination": "npx tsx scripts/verify-application-lease-termination.ts",
    "uat:property:deactivation-recovery": "npx tsx scripts/verify-property-deactivation-recovery.ts",
    "uat:ui:dashboards": "npx tsx scripts/verify-dashboards.ts",
    "uat:access:role-redirection": "node scripts/test-role-based-redirection.js",
    "uat:cycle1:smoke": "npm run uat:setup:db && npm run uat:setup:coa && npm run uat:finance:smoke && npm run uat:payments:strategy && npm run uat:dss:seed-notarize",
    "uat:cycle1:smoke:with-notarize": "npm run uat:cycle1:smoke && npm run uat:dss:notarize -- -DocumentId %npm_config_documentid%",
    "uat:cycle2:core": "npm run uat:finance:lease-activation && npm run uat:finance:verify-core && npm run uat:finance:utilities && npm run uat:finance:maintenance && npm run uat:finance:rent-roll && npm run uat:finance:summary",
    "uat:cycle2:core:extended": "npm run uat:cycle2:core && npm run uat:property:listing-lifecycle && npm run uat:property:application-lease-termination",
    "uat:cycle3:regression": "npm run uat:finance:smoke && npm run uat:payments:strategy && npm run uat:dss:seed-notarize && npm run uat:finance:verify-core && npm run uat:finance:utilities && npm run uat:finance:maintenance",
    "uat:cycle3:regression:extended": "npm run uat:cycle3:regression && npm run uat:property:deactivation-recovery",
    "uat:cycle3:regression:with-notarize": "npm run uat:cycle3:regression && npm run uat:dss:notarize -- -DocumentId %npm_config_documentid%",
    "// --- ORCHESTRATION & CI PIPELINES ---": "",
    "test:all": "npm run check:hardcoded-runtime && npm run test:unit && npm run test:integration && npm run test:e2e:ci",
    "test:ci": "npm run check:hardcoded-runtime && npm run test:unit && npm run test:integration && npm run test:e2e:ci",
    "// --- TEST DATABASE MANAGEMENT ---": "",
    "docker:test:up": "docker-compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down",
    "docker:test:clean": "docker-compose -f docker-compose.test.yml down -v"
  },
